{
  "name": "snippet-archiver",
  "version": "1.0.0",
  "description": "Snippet Archiver with Electron and React",
  "main": "dist/main/main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -w -p .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"wait-on http://localhost:3000 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p .",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/iconv-lite": "^0.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "iconv-lite": "^0.7.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "lucide-react": "^0.474.0"
  }
}
